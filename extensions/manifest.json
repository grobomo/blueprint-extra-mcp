{
  "manifest_version": 3,
  "name": "Blueprint Extra MCP for Chrome",
  "version": "1.9.21",
  "description": "Browser automation for Claude via MCP. Fork with iframe snapshots, incognito tab recognition, relay fixes.",
  "default_locale": "en",
  "permissions": [
    "alarms",
    "debugger",
    "activeTab",
    "tabs",
    "storage",
    "management",
    "webRequest",
    "webNavigation",
    "scripting",
    "offscreen",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>",
    "*://*.railsblueprint.com/*",
    "*://*.blueprintmcp.com/*"
  ],
  "background": {
    "service_worker": "chrome/src/background-module.js",
    "type": "module"
  },
  "action": {
    "default_title": "Blueprint Extra MCP for Chrome",
    "default_popup": "chrome/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["chrome/src/content-script.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}
