{
  "id": "add-detection-exclusion",
  "name": "Add Detection Model Exclusion",
  "description": "Create an exception in Detection Model Management to suppress specific detections on specific endpoints",
  "urlHint": "#/app/dm",
  "params": {
    "exceptionName": { "type": "string", "required": true, "description": "Human-readable exception name" },
    "description": { "type": "string", "required": false, "description": "Why this exception exists" },
    "targetField": { "type": "string", "required": true, "default": "endpointHostName", "description": "Target field type" },
    "targetValue": { "type": "string", "required": true, "description": "Target value (e.g., hostname)" },
    "eventType": { "type": "string", "required": false, "default": "ALL", "description": "Event source type filter" }
  },
  "steps": [
    {
      "id": "navigate",
      "action": "navigate_sidebar",
      "description": "Navigate to Detection Model Management via sidebar",
      "sidebarPath": ["Agentic SIEM and XDR", "Detection Model Management"],
      "sidebarSelector": "#menuxdr_app",
      "targetText": "Detection Model Management",
      "verify": { "titleContains": "Detection Model Management" }
    },
    {
      "id": "open_exceptions_tab",
      "action": "click_in_iframe",
      "description": "Click Exceptions tab",
      "iframePattern": "__DETECTIONMODEL_CONTAINER",
      "findElement": { "role": "tab", "text": "Exceptions" },
      "fallback": "find tab-like element containing text 'Exceptions'"
    },
    {
      "id": "click_add",
      "action": "click_in_iframe",
      "description": "Click Add button",
      "iframePattern": "__DETECTIONMODEL_CONTAINER",
      "findElement": { "tag": "button", "textContains": "Add" },
      "verify": { "formVisible": true }
    },
    {
      "id": "fill_name",
      "action": "fill_in_iframe",
      "description": "Fill exception name",
      "iframePattern": "__DETECTIONMODEL_CONTAINER",
      "findElement": { "tag": "input", "index": 0, "nearLabel": "Exception name" },
      "valueFrom": "params.exceptionName",
      "inputMethod": "nativeSetter"
    },
    {
      "id": "fill_description",
      "action": "fill_in_iframe",
      "description": "Fill description",
      "iframePattern": "__DETECTIONMODEL_CONTAINER",
      "findElement": { "tag": "textarea", "index": 0, "nearLabel": "Description" },
      "valueFrom": "params.description",
      "inputMethod": "nativeSetter"
    },
    {
      "id": "select_target_field",
      "action": "antd_select_in_iframe",
      "description": "Select target field type",
      "iframePattern": "__DETECTIONMODEL_CONTAINER",
      "selectIndex": 0,
      "valueFrom": "params.targetField",
      "notes": "Ant Design Select - needs mousedown+mouseup+click on search input to open, then click matching option"
    },
    {
      "id": "fill_target_value",
      "action": "antd_select_in_iframe",
      "description": "Enter target value",
      "iframePattern": "__DETECTIONMODEL_CONTAINER",
      "selectIndex": 1,
      "valueFrom": "params.targetValue",
      "inputMethod": "tag_input",
      "notes": "This is a tag-style input. Type value via nativeSetter + input event, then press Enter to confirm as tag"
    },
    {
      "id": "select_event_type",
      "action": "antd_select_in_iframe",
      "description": "Select event type",
      "iframePattern": "__DETECTIONMODEL_CONTAINER",
      "selectIndex": 2,
      "valueFrom": "params.eventType",
      "notes": "Selecting ALL removes the need for Event ID and Event sub-ID sub-selectors"
    },
    {
      "id": "submit",
      "action": "click_in_iframe",
      "description": "Click Add button to submit",
      "iframePattern": "__DETECTIONMODEL_CONTAINER",
      "findElement": { "tag": "button", "text": "Add", "enabled": true },
      "verify": { "navigatedAway": true, "listVisible": true }
    }
  ],
  "elementNotes": {
    "dynamicIds": "V1 does NOT use dynamic element IDs for these form elements. CSS classes (css-*) are generated by emotion/styled-components and ARE dynamic per build but stable within a session. Use structural selectors (tag + index + nearLabel) rather than class names.",
    "antDesignSelects": "All dropdowns are Ant Design Select components. They share a global dropdown portal DOM node. To open: focus the .ant-select-selection-search-input, then dispatch mousedown+mouseup+click with view=iframe.contentWindow. Options appear in .ant-select-item-option elements inside .ant-select-dropdown:not(.ant-select-dropdown-hidden).",
    "iframeOverlay": "Handled automatically by vision-one site playbook preAction.",
    "mfaModal": "Handled automatically by vision-one site playbook preAction."
  }
}
